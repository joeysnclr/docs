{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Surface",
  "colors": {
    "primary": "#111111",
    "light": "#374151",
    "dark": "#030712"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "light",
    "strict": true
  },
  "navigation": {
    "tabs": [
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction",
              "quickstart"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/match"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "surface.surf",
          "href": "https://surface.surf",
          "icon": "arrow-up-right-from-square"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "surface.surf",
        "href": "https://surface.surf"
      }
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/surfacepm"
    }
  }
}
